{
  "name": "@codigos/lane-x",
  "version": "1.0.25",
  "description": "A minimal, high-performance fine-grained reactive runtime with priority-lane scheduling",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn build",
    "bump": "npm run  ./scripts/bump-version.js"
  },
  "keywords": [
    "reactive",
    "signals",
    "fine-grained",
    "state-management",
    "scheduler",
    "lanes",
    "computed",
    "effects"
  ],
  "author": "Alex Rosano",
